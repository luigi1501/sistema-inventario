<%- include('partials/header') %>

<div class="container">
    <header class="section-header">
        <h1>📜 Historial de Ventas</h1>
        <p>Registro de transacciones - <%= new Date().getFullYear() %></p>
    </header>

    <div class="stats-container">
        <div class="stat-card">
            <span class="stat-title">INGRESOS TOTALES</span>
            <span class="stat-value">
                $<%= ventas.reduce((acc, v) => acc + parseFloat(v.total_venta), 0).toFixed(2) %>
            </span>
        </div>
    </div>

    <div class="table-container">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 10px;">
            <h2 style="margin: 0;">Registro Detallado</h2>
            
            <div style="display: flex; gap: 10px;">
                <button id="openChartModal" class="btn-save" 
                    style="background: #4361ee; color: white; border: none; padding: 12px 20px; border-radius: 8px; cursor: pointer; font-weight: bold; display: flex; align-items: center; gap: 10px;">
                    📊 Ver Gráfica
                </button>

                <button id="exportVentasPDF" class="btn-save" 
                    style="background: #ef233c; color: white; border: none; padding: 12px 20px; border-radius: 8px; cursor: pointer; font-weight: bold; display: flex; align-items: center; gap: 10px;">
                    📄 Descargar Reporte PDF
                </button>
            </div>
        </div>
        
        <div class="table-wrapper">
            <table id="salesTable">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Tipo / Categoría</th> <th>Producto</th>
                        <th>Cant.</th>
                        <th>Precio</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (ventas.length === 0) { %>
                        <tr>
                            <td colspan="6" style="text-align: center; padding: 20px; color: #64748b;">No hay ventas registradas.</td>
                        </tr>
                    <% } %>
                    <% ventas.forEach(v => { %>
                        <tr class="sales-row">
                            <td><%= new Date(v.fecha).toLocaleString() %></td>
                            <td>
                                <span style="background: #f1f5f9; padding: 4px 8px; border-radius: 6px; font-size: 0.85rem; color: #475569; font-weight: 600;">
                                    <%= v.categoria_producto || 'General' %>
                                </span>
                            </td>
                            <td><strong><%= v.nombre_producto %></strong></td>
                            <td><%= v.cantidad %></td>
                            <td>$<%= v.precio_unitario %></td>
                            <td class="total-cell" style="color: #06d6a0; font-weight: bold;">$<%= v.total_venta %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="chartModal" style="display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.6); align-items: center; justify-content: center; backdrop-filter: blur(4px);">
    <div style="background-color: white; padding: 30px; border-radius: 15px; width: 90%; max-width: 850px; position: relative; box-shadow: 0 10px 30px rgba(0,0,0,0.4);">
        <span id="closeModal" style="position: absolute; right: 20px; top: 15px; font-size: 30px; font-weight: bold; cursor: pointer; color: #999;">&times;</span>
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-right: 40px; margin-bottom: 10px;">
            <h2 style="margin: 0; color: #2d3436; display: flex; align-items: center; gap: 10px;">
                📊 Análisis de Ventas
            </h2>
            <select id="chartGroupSelector" style="padding: 8px 12px; border-radius: 8px; border: 1px solid #ddd; outline: none; font-weight: 600; cursor: pointer;">
                <option value="producto">Por Producto</option>
                <option value="categoria">Por Categoría</option>
            </select>
        </div>

        <hr style="border: 0; border-top: 1px solid #eee; margin-bottom: 20px;">
        
        <div style="height: 450px; width: 100%;">
            <canvas id="ventasChart"></canvas>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.25/jspdf.plugin.autotable.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
<script src="/javascripts/ventas.js"></script>

<%- include('partials/footer') %>