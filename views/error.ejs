<%- include('partials/header') %>

<div class="container" style="text-align: center; padding: 5rem 1rem;">
    <div class="error-visual" style="font-size: 8rem; margin-bottom: 1rem; filter: drop-shadow(0 10px 15px rgba(0,0,0,0.1));">
        🚀
    </div>
    
    <h1 style="font-size: 3rem; color: var(--primary-dark); margin: 0;">
        <%= error.status || 404 %>
    </h1>
    
    <h2 style="color: var(--secondary); margin-bottom: 1.5rem;">
        ¡Oops! Parece que te has salido de la órbita.
    </h2>
    
    <p style="color: #64748b; max-width: 500px; margin: 0 auto 2rem; font-size: 1.1rem;">
        <%= message || "La página que buscas no existe o ha sido movida a otra dimensión." %>
    </p>

    <div class="error-actions" style="display: flex; justify-content: center; gap: 15px;">
        <a href="/" class="btn-save" style="text-decoration: none; display: inline-block;">
            🏠 Volver al Inicio
        </a>
    </div>

    <% if (error.stack) { %>
        <details style="margin-top: 4rem; text-align: left; background: #f1f5f9; padding: 1rem; border-radius: 8px; cursor: pointer;">
            <summary style="font-weight: 700; color: #64748b; font-size: 0.8rem;">
                🛠️ Información técnica (Modo Desarrollador)
            </summary>
            <pre style="font-size: 0.75rem; color: #ef233c; overflow-x: auto; margin-top: 1rem; white-space: pre-wrap;">
                <%= error.stack %>
            </pre>
        </details>
    <% } %>
</div>

<%- include('partials/footer') %>